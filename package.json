{
  "name": "@syldel/micro-clack",
  "version": "0.1.3",
  "description": "Minimal interactive CLI prompts, zero dependencies",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Syldel/micro-clack.git"
  },
  "bugs": {
    "url": "https://github.com/Syldel/micro-clack/issues"
  },
  "homepage": "https://github.com/Syldel/micro-clack#readme",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "ts-node --files scripts/demo.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist",
    "build": "npm run lint && npm run clean && tsc -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm version patch && npm publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "prompt",
    "interactive",
    "typescript",
    "zero-dependency"
  ],
  "author": "Syl. D.",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsonc": "^3.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
